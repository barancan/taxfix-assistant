# ---------------------------------------------------------------------------
# Taxfix AI Tax Assistant (POC) — environment reference
# Copy to .env.local and fill in. NEVER commit real secrets. Placeholders only.
# ---------------------------------------------------------------------------

# Demo marker on invoices and sensitive UI. Keep true for the POC.
DEMO_MODE=true

# --- AI providers (server-only; never exposed to the browser) --------------
# Default provider used in server-funded mode: "anthropic" | "openai"
AI_DEFAULT_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5.4

# Allow the user to supply their own key (BYOK) from the UI. Key is held in
# browser memory only and forwarded per-request; never persisted or logged.
AI_ALLOW_BYOK=true

# Observable, opt-in only. Disabled by default. No silent provider fallback.
AI_SERVER_FALLBACK=false

# --- Supabase (server-only; leave unset to run in local demo persistence) --
# When these are absent the app runs the local mock store and shows a banner.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=invoices

# --- Session signing -------------------------------------------------------
# 32+ byte random secret used to HMAC-sign the opaque session cookie.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-value
